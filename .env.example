# ============================================================
#  BSC Ticket Management — environment variables
#  Copy to .env for local dev. In Vercel, add these under
#  Project -> Settings -> Environment Variables.  NEVER commit .env.
# ============================================================

# --- Database (Neon) ---------------------------------------
# Use the POOLED connection string (host contains "-pooler").
DATABASE_URL=postgresql://user:pass@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# --- Auth ---------------------------------------------------
JWT_SECRET=replace-with-a-long-random-string
DEFAULT_PASSWORD=Bsc@123

# --- Vercel Cron protection ---------------------------------
CRON_SECRET=replace-with-a-long-random-string

# --- Microsoft Graph (OneDrive + Excel log + mail) ----------
# Azure app registration with Files.ReadWrite.All + Mail.Send (application perms).
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_DRIVE_USER=hr@bharatsteels.in
GRAPH_ROOT_FOLDER=Ticket Management System

# --- WATI (WhatsApp) ----------------------------------------
# From your WATI dashboard (API Docs). BASE looks like https://live-server-xxxxx.wati.io
WATI_BASE_URL=
WATI_TOKEN=
